APP_NAME=OeParts
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── SQLite in-memory (set by phpunit.xml — kept here for artisan commands) ──
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# ─── All drivers set to fast in-process alternatives ─────────────────────────
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# ─── Mail captured in-memory (assert in tests, never sent) ──────────────────
MAIL_MAILER=array
MAIL_FROM_ADDRESS=test@oeparts.test
MAIL_FROM_NAME=OeParts

# ─── Airwallex (stubbed for tests) ──────────────────────────────────────────
AIRWALLEX_CLIENT_ID=test_client_id
AIRWALLEX_API_KEY=test_api_key
AIRWALLEX_WEBHOOK_SECRET=test_webhook_secret
AIRWALLEX_ENV=demo

# ─── Filesystem ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

BCRYPT_ROUNDS=4
