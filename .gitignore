# ============================================================
# OeParts — .gitignore
# ============================================================

# Laravel framework
/.phpunit.cache
/node_modules
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
/auth.json

# Stray sqlite artifact some phpunit/Sail test runs leave at repo root
/testing
/testing-journal

# Playwright
/test-results
/playwright-report
/tests/e2e/.auth

# Test-runtime disk output (backup/restore fixtures, generated invoices, etc.
# from PHPUnit's local/public testing disks) — never real project content.
/storage/framework/testing/

# Manual pre-refactor code snapshots (ad-hoc, not a real backup mechanism —
# the actual Backup Engine writes to storage/app/, not here).
/storage/dashboard-backups/

# Environment — only .env.example, .env.testing, and the committed Docker env
# templates are tracked (the real .env stays local/untracked).
.env
.env.*
!.env.example
!.env.testing
!.env.docker.example
!.env.docker.hostingsim

# PHPUnit / Pest
.phpunit.result.cache
.phpunit.cache

# Homestead (legacy)
Homestead.json
Homestead.yaml

# Compiled / build outputs (generic)
dist/
build/

# IMPORTANT: public/build/ MUST be committed — production server has no Node.js.
# The generic `build/` rule above would otherwise exclude it, so we re-include it here.
!public/build/
!public/build/**

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary / cache
*.tmp
*.temp
.cache/

# ============================================================
# Dev / Debug artifacts (prevent future accidents)
# ============================================================
temp_check*.php
test_check*.php
debug_check*.php
db_search.php
temp_cookies.txt
test_cookies.txt
scratch/

# Debug files accidentally placed in public/
public/test_*.php
public/debug_*.php
public/info.php
public/phpinfo.php

# Backup files
*.bak
*.backup
*.orig
*.old

# ============================================================
# IDE & editor files
# ============================================================
/.fleet
/.idea
/.nova
/.vscode
/.zed
.cursor/
*.swp
*.swo
*.kate-swp

# ============================================================
# OS / system files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
