# ============================================================
# OeParts — .gitignore
# ============================================================

# Laravel framework
/.phpunit.cache
/node_modules
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
/auth.json

# Stray sqlite artifact some phpunit/Sail test runs leave at repo root
/testing
/testing-journal

# Google Drive Desktop's own sync staging folders (this project folder is
# synced to Google Drive on this machine) — transient, never project content.
/.tmp.drivedownload
/.tmp.driveupload

# Playwright
/test-results
/playwright-report
/tests/e2e/.auth

# Test-runtime disk output (backup/restore fixtures, generated invoices, etc.
# from PHPUnit's local/public testing disks) — never real project content.
/storage/framework/testing/

# Manual pre-refactor code snapshots (ad-hoc, not a real backup mechanism —
# the actual Backup Engine writes to storage/app/, not here).
/storage/dashboard-backups/

# Environment — only .env.example, .env.testing, and the committed Docker env
# templates are tracked (the real .env stays local/untracked).
.env
.env.*
!.env.example
!.env.testing
!.env.docker.example
!.env.docker.hostingsim
!.env.docker.overrides

# PHPUnit / Pest
.phpunit.result.cache
.phpunit.cache

# Homestead (legacy)
Homestead.json
Homestead.yaml

# Compiled / build outputs (generic)
dist/
build/

# IMPORTANT: public/build/ MUST be committed — production server has no Node.js.
# The generic `build/` rule above would otherwise exclude it, so we re-include it here.
!public/build/
!public/build/**

# Generated sitemap output (App\Services\SitemapService via `sitemap:generate`,
# scheduled daily — see routes/console.php). Never commit these: a static
# public/sitemap.xml on disk silently shadows the dynamic route entirely
# (docker/serve-router.php serves any file that exists on disk before Laravel
# routing ever runs — same root cause as robots.txt below). This is exactly
# what happened here — an initial-scaffold sitemap.xml pointing at a
# now-dead domain (oemhub.test) sat committed and untouched for 40+ days,
# because nothing regenerated it in this environment. robots.txt is
# similarly meant to be served ONLY by App\Http\Controllers\RobotsController
# (environment-aware Disallow rules + Sitemap: directive) — never add a
# static public/robots.txt back.
/public/sitemap.xml
/public/sitemaps/
/public/robots.txt

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary / cache
*.tmp
*.temp
.cache/

# ============================================================
# Dev / Debug artifacts (prevent future accidents)
# ============================================================
temp_check*.php
test_check*.php
debug_check*.php
db_search.php
temp_cookies.txt
test_cookies.txt
scratch/

# Debug files accidentally placed in public/
public/test_*.php
public/debug_*.php
public/info.php
public/phpinfo.php

# Backup files
*.bak
*.backup
*.orig
*.old

# ============================================================
# IDE & editor files
# ============================================================
/.fleet
/.idea
/.nova
# .vscode is ignored by default (personal IDE state), except the shared
# workspace config this project checks in on purpose (extensions, Xdebug
# launch config, formatter settings) — see docs/DOCKER_DEV_ENVIRONMENT.md.
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json
!/.vscode/launch.json
/.zed
.cursor/
*.swp
*.swo
*.kate-swp

# ============================================================
# Internal / not for the public repo
# ============================================================
# AI coding-assistant config and internal dev-process docs — used locally,
# never published. Keep these out of git entirely (not just untracked-by-
# convention) so a stray `git add -A` can't resurface them.
/CLAUDE.md
/.claude/
/AGENTS.md
/PRD.md
/docs/

# ============================================================
# OS / system files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
