APP_NAME=OeParts
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Sail container ────────────────────────────────────────────────────────────
# php artisan sail:install sets these via the shell, not this file — kept here so
# `cp .env.docker.example .env` is a complete, working starting point.
APP_PORT=80
VITE_PORT=5173
WWWUSER=1000
WWWGROUP=1000
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

# ─── Database — Docker service hostname, not 127.0.0.1 ────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=oeparts
DB_USERNAME=sail
DB_PASSWORD=password

# ─── Cache / Sessions / Queues ─────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis

# ─── Redis — Docker service hostname ───────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail — Mailpit captures everything locally, view at http://localhost:8025 ─
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@oeparts.test
MAIL_FROM_NAME="${APP_NAME}"

# ─── Airwallex Payments ────────────────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_ENV=demo

# ─── AWS (optional — for file storage) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Update & Recovery System (Module 21) ─────────────────────────────────────
OE_UPDATE_ENABLED=true
OE_UPDATE_CHANNEL=stable
OE_UPDATE_AUTO_SECURITY=false

OE_BACKUP_KEY=
OE_BACKUP_DISK=local

OE_RECOVERY_KEY=

# ─── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
