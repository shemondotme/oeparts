APP_NAME=OeParts
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oeparts
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / Sessions / Queues ─────────────────────────────────────────────────
# Production: use redis for all three
# Local (XAMPP, no Redis): use array/file/sync
CACHE_STORE=redis
CACHE_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Airwallex Payments ────────────────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_ENV=demo

# ─── AWS (optional — for file storage) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Update & Recovery System (Module 21) ─────────────────────────────────────
OE_UPDATE_ENABLED=true
OE_UPDATE_CHANNEL=stable
OE_UPDATE_AUTO_SECURITY=false
# OE_UPDATE_CHECK_URL=
# OE_UPDATE_CATALOG_URL=

# Backups — encryption is MANDATORY (backups hold customer PII / GDPR).
# Generate a strong random key and BACK IT UP: losing it makes every encrypted
# backup unrecoverable. Use a dedicated key, NOT APP_KEY. e.g. `openssl rand -base64 32`
OE_BACKUP_KEY=
OE_BACKUP_DISK=local
# OE_BACKUP_SCHEDULE=true

# Recovery console (public/oe-recovery.php) — disabled unless a key is set.
OE_RECOVERY_KEY=
# OE_RECOVERY_IP_ALLOWLIST=203.0.113.4,198.51.100.7
# Recovery console hardening (optional — sensible defaults shown):
# OE_RECOVERY_MAX_ATTEMPTS=5         # failed key/token attempts before lockout
# OE_RECOVERY_LOCKOUT_SECONDS=900    # lockout + failure-count window (seconds)
# OE_RECOVERY_TOKEN_TTL=900          # confirm-token lifetime (seconds)

# Release signature verification (RSA-SHA256). When a public key is set, updates are
# authenticated (not just checksummed) and an unsigned/tampered release is BLOCKED at
# pre-flight. Public key is app-baked (ships with each release, or committed to
# resources/keys/release-public.pem). PRIVATE key is a build/CI secret — NEVER commit it.
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out release-private.pem
#   openssl rsa -in release-private.pem -pubout -out release-public.pem
# OE_RELEASE_PUBLIC_KEY=            # PEM (or commit resources/keys/release-public.pem)
# OE_RELEASE_PRIVATE_KEY=          # PEM — CI secret only, on the release runner

# ─── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
