@php
    $lang = app()->getLocale();

    $matchBadge = match($search_type) {
        'exact'           => ['label' => 'Exact Match',           'bg' => 'bg-emerald-100', 'text' => 'text-emerald-700', 'icon' => 'check-circle'],
        'cross_reference' => ['label' => 'Cross-Reference Match', 'bg' => 'bg-blue-100',    'text' => 'text-blue-700',    'icon' => 'arrow-path'],
        'partial'         => ['label' => 'Partial Match',         'bg' => 'bg-amber/15',    'text' => 'text-amber-text',  'icon' => 'magnifying-glass'],
        default           => ['label' => 'Match',                 'bg' => 'bg-gray-100',    'text' => 'text-gray-600',    'icon' => 'check-circle'],
    };

    // VAT multiplier using bcmath — e.g. 21% → '1.2100'
    $vatMultiplier = bcadd('1', bcdiv((string) $vat_rate, '100', 4), 4);

    // Active filter count
    $activeFilterCount = ($condition_filter ? 1 : 0)
                       + ($in_stock_only ? 1 : 0)
                       + ($sort !== 'default' ? 1 : 0)
                       + ($manufacturer_filter ? 1 : 0);
@endphp

