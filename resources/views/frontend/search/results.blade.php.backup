                                    : '{{ $conditionStyles[$val]['idle'] }}'"
                                class="px-3 py-1.5 rounded-lg text-xs font-semibold border transition-all">
                            {{ $label }} ({{ $cnt }})
                        </button>
                        @endif
                        @endforeach
                    </div>
                </div>

