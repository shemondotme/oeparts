{{-- ── Custom Styles: Data Table Pro ───────────────────────────────────── --}}
@push('styles')
<style>
    /* Table row hover accent bar */
    .table-row-accent {
        position: relative;
    }
    .table-row-accent::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(to bottom, #F59E0B, #F97316);
        transform: scaleY(0);
        transition: transform 0.2s ease;
        border-radius: 0 2px 2px 0;
    }
    .table-row-accent:hover::before {
        transform: scaleY(1);
    }

    /* Price highlight vs average */
    .price-below-avg {
        color: #059669;
    }
    .price-above-avg {
        color: #DC2626;
    }

    /* Sticky column shadows */
    .sticky-col-left {
        position: sticky;
        left: 0;
        z-index: 10;
        background: inherit;
    }
    .sticky-col-left::after {
        content: '';
        position: absolute;
        right: -8px;
        top: 0;
        bottom: 0;
        width: 8px;
        background: linear-gradient(to right, rgba(0,0,0,0.04), transparent);
        pointer-events: none;
    }
    .sticky-col-right {
        position: sticky;
        right: 0;
        z-index: 10;
        background: inherit;
    }
    .sticky-col-right::before {
        content: '';
        position: absolute;
        left: -8px;
        top: 0;
        bottom: 0;
        width: 8px;
        background: linear-gradient(to left, rgba(0,0,0,0.04), transparent);
        pointer-events: none;
    }

    /* Filter drawer slide-up on mobile */
    .filter-drawer {
        transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.3s ease;
    }

    /* Row stagger animation */
    @keyframes rowSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .row-animate {
        animation: rowSlideIn 0.35s ease-out both;
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .table-row-accent::before,
        .row-animate,
        .filter-drawer {
            animation: none !important;
            transition: none !important;
        }
    }
</style>
@endpush

