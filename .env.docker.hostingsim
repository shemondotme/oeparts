# Overrides for compose.yaml's `hostingsim` service (docker compose --profile
# hostingsim up). Docker Compose sets these as real container environment
# variables, which Laravel's Dotenv treats as already-set and never overwrites —
# so these values win over whatever the bind-mounted .env file says, without a
# second full .env file to keep in sync. Only the keys that must differ from a
# normal Docker dev run are listed here; everything else (DB credentials, app
# key, etc.) still comes from the mounted .env.
#
# Forces the cheapest-tier shared-hosting reality (CLAUDE.md rules #41-52): no
# Redis, no guaranteed queue worker, sync queue instead.
DB_HOST=mysql

QUEUE_CONNECTION=sync
CACHE_STORE=file
SESSION_DRIVER=file
MAIL_MAILER=log
